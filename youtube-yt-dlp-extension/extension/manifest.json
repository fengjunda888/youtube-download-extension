{
  "manifest_version": 3,
  "name": "YouTube yt-dlp Downloader",
  "version": "0.2.0",
  "description": "YouTube downloader by fengjunda888, powered by yt-dlp.",
  "author": "fengjunda888",
  "homepage_url": "https://github.com/fengjunda888/youtube-download-extension",
  "key": "",
  "permissions": ["activeTab", "tabs", "nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Download with yt-dlp",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
